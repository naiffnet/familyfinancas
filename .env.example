# ═══════════════════════════════════════════
# Variáveis de Ambiente — FinançasFamília
# ═══════════════════════════════════════════
# Copie este arquivo como .env e preencha os valores
# apenas se for rodar em produção fora do Render.
#
# NOTA: No Render, essas variáveis são configuradas
# diretamente pelo Dashboard ou pelo render.yaml.
# ═══════════════════════════════════════════

# Porta do servidor (default: 3000)
# Render define isso automaticamente como 10000
PORT=3000

# Ambiente (development | production)
NODE_ENV=production

# Caminho customizado do banco SQLite (opcional)
# DB_PATH=/data/financeiro.db

# ── SEGURANÇA E COMPLIANCE (LGPD) ──────────────────────────────────────────
# Chave de criptografia simétrica para CPFs em repouso (32 bytes em hexadecimal).
# Deve ser gerada com `crypto.randomBytes(32).toString('hex')`
DATA_ENCRYPTION_KEY=

# Chave secreta para operações de administração e download binário do banco.
# Deve ter pelo menos 16 caracteres e ser mantida em sigilo.
ADMIN_OPERATION_KEY=

